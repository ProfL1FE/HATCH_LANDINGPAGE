# Copy this file to .env and fill in your real values.
# Supabase project URL and anon (public) key — find these in your Supabase
# project's Settings -> API page. The anon key is safe to expose in a
# frontend app; it's the one designed for this.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
